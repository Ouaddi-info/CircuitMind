        <module>circuitmind-core</module>
        <module>circuitmind-json</module>
        <module>circuitmind-engine</module>
        <module>circuitmind-spring-boot-starter</module>
        <module>circuitmind-observability</module>
    </modules>
	<groupId>io.circuitmind</groupId>
	<artifactId>circuitmind</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name/>
	<description/>
	<url/>
	<licenses>
		<license/>
